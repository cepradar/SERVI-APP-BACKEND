        <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA["Fecha: " + $P{VENTA_FECHA}]]></textFieldExpression>
      </textField>

      <!-- Sección FACTURAR A + VENDEDOR -->
      <staticText>
        <reportElement x="0" y="80" width="100" height="14" uuid="522dd4b2-e383-4b40-9eb0-93d9a7730db3"/>
        <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
        <text><![CDATA[FACTURAR A:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="94" width="260" height="14" uuid="f2039ae1-ce20-49c9-a8fe-824c77b58a18"/>
        <textElement><font fontName="SansSerif" size="9" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{CLIENTE_NOMBRE}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="108" width="260" height="12" uuid="bb51c2c7-8d6d-4b31-a33d-0a7f890e80af"/>
        <textElement><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA["Doc: " + $P{CLIENTE_DOCUMENTO} + "  Tel: " + $P{CLIENTE_TELEFONO}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="0" y="120" width="260" height="12" uuid="1d83c051-d907-4b6d-ac54-6d5490411008"/>
        <textElement><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA[$P{CLIENTE_EMAIL}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="300" y="80" width="80" height="14" uuid="8e636f17-6007-48db-8b96-b08f01a02e08"/>
        <textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement>
        <text><![CDATA[VENDEDOR:]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="300" y="94" width="235" height="14" uuid="b7c46eb1-7021-4ffb-9f80-6e00997231a7"/>
        <textElement><font fontName="SansSerif" size="9"/></textElement>
        <textFieldExpression><![CDATA[$P{VENDEDOR_NOMBRE}]]></textFieldExpression>
      </textField>

      <!-- Línea divisoria -->
      <line>
        <reportElement x="0" y="148" width="535" height="1" forecolor="#1e3a5f" uuid="4f927ea2-c4d6-4665-9f9a-725ead028b19"/>
        <graphicElement><pen lineWidth="1.5"/></graphicElement>
      </line>
    </band>
  </title>

