<?xml version="1.0" encoding="UTF-8"?>
<!-- Plantilla de Factura de Venta - JasperReports 6.x -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="factura"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30"
              uuid="a1b2c3d4-0001-0001-0001-000000000001">

  <!-- ═══════════════════ Parámetros ═══════════════════ -->
  <parameter name="EMPRESA_NOMBRE"    class="java.lang.String"><defaultValueExpression><![CDATA["Mi Empresa"]]></defaultValueExpression></parameter>
  <parameter name="EMPRESA_NIT"       class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="EMPRESA_DIRECCION" class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="EMPRESA_TELEFONO"  class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="EMPRESA_EMAIL"     class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="VENTA_ID"          class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="VENTA_FECHA"       class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="VENTA_TOTAL"       class="java.lang.String"><defaultValueExpression><![CDATA["$ 0.00"]]></defaultValueExpression></parameter>
  <parameter name="VENTA_OBSERVACIONES" class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="CLIENTE_NOMBRE"    class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="CLIENTE_DOCUMENTO" class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="CLIENTE_TELEFONO"  class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="CLIENTE_EMAIL"     class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>
  <parameter name="VENDEDOR_NOMBRE"   class="java.lang.String"><defaultValueExpression><![CDATA[""]]></defaultValueExpression></parameter>

  <!-- ═══════════════════ Campos del datasource ═══════════════════ -->
  <field name="productNombre"   class="java.lang.String"/>
  <field name="cantidad"        class="java.lang.Integer"/>
  <field name="precioUnitario"  class="java.math.BigDecimal"/>
  <field name="subtotal"        class="java.math.BigDecimal"/>

  <!-- ═══════════════════ Variables ═══════════════════ -->
  <variable name="TOTAL_ACUM" class="java.math.BigDecimal" calculation="Sum" resetType="Report">
    <variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
    <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
  </variable>
  <variable name="FILA_COLOR" class="java.lang.Boolean" calculation="Count" resetType="Report">
    <variableExpression><![CDATA[true]]></variableExpression>
  </variable>

  <!-- ═══════════════════ TITLE BAND — Encabezado empresa + cliente ═══════════════════ -->
  <title>
    <band height="175" splitType="Stretch">

      <!-- Fondo encabezado empresa -->
      <rectangle>
        <reportElement x="0" y="0" width="535" height="70" backcolor="#1e3a5f" forecolor="#1e3a5f" uuid="aa587ec5-9181-4815-812e-d6d5fac2a0ae"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>

      <!-- Nombre empresa -->
      <textField isBlankWhenNull="true">
        <reportElement x="10" y="8" width="350" height="28" forecolor="#FFFFFF" uuid="334e3d02-50a7-4ff7-89f9-7d4f79e3ea50"/>
        <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="16" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{EMPRESA_NOMBRE}]]></textFieldExpression>
      </textField>

      <!-- NIT -->
