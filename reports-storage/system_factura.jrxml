        <textElement><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA["NIT: " + $P{EMPRESA_NIT}]]></textFieldExpression>
      </textField>
      <!-- Tel + email -->
      <textField isBlankWhenNull="true">
        <reportElement x="10" y="50" width="350" height="14" forecolor="#b0c4de" uuid="a3b814ff-b2a9-4e7e-92cb-95e0ed12381a"/>
        <textElement><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA[$P{EMPRESA_TELEFONO} + "  |  " + $P{EMPRESA_EMAIL}]]></textFieldExpression>
      </textField>

      <!-- FACTURA label (derecha) -->
      <staticText>
        <reportElement x="385" y="5" width="140" height="30" forecolor="#FFFFFF" uuid="8e57a5ec-8c87-45ef-b7a1-0d2492540bd9"/>
        <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="20" isBold="true"/></textElement>
        <text><![CDATA[FACTURA]]></text>
      </staticText>
      <textField isBlankWhenNull="true">
        <reportElement x="385" y="35" width="140" height="14" forecolor="#b0c4de" uuid="9962ee57-6a14-4ede-8d55-5691f333f079"/>
        <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
        <textFieldExpression><![CDATA["No. " + $P{VENTA_ID}]]></textFieldExpression>
      </textField>
