# ============================================================
# inventory-backend — Variables de entorno (EJEMPLO)
# Copia este archivo a .env y ajusta los valores.
# NUNCA comitas el .env real al repositorio.
# ============================================================

# ============================================================
# BASE DE DATOS POSTGRESQL
# ============================================================
POSTGRES_DB=SERVI
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DB_PORT=5432

# ============================================================
# CONEXIÓN DATASOURCE (Spring Boot)
# Úsalo tanto en despliegue directo como en Docker.
# ============================================================
DB_URL=jdbc:postgresql://localhost:5432/SERVI
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================================
# JWT - AUTENTICACIÓN
# Genera un secreto seguro: openssl rand -base64 64
# Ejemplo: V/Yw70P*V-?eEqV=C2x^F6%r@3*?[K_G
# ============================================================
JWT_SECRET=your_jwt_secret_key_min_64_characters_very_secure
JWT_EXPIRATION_MS=36000000

# ============================================================
# CORS (orígenes permitidos separados por coma)
# ============================================================
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.com

# ============================================================
# SERVIDOR
# ============================================================
SERVER_PORT=8080

# ============================================================
# MIGRACIONES DE BASE DE DATOS
# Opciones: validate, update, create, create-drop
# Producción: usar 'validate'
# ============================================================
DDL_AUTO=validate

# ============================================================
# ALMACENAMIENTO DE REPORTES
# ============================================================
REPORTS_STORAGE_PATH=/var/lib/inventory-backend/reports-storage
