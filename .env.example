# ============================================================
# inventory-backend — Variables de entorno (EJEMPLO)
# Copia este archivo a .env y ajusta los valores.
# NUNCA comitas el .env real al repositorio.
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/SERVI
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── JWT ──────────────────────────────────────────────────────
# Genera un secreto seguro: openssl rand -base64 64
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_256_bits
JWT_EXPIRATION_MS=36000000

# ── CORS (orígenes permitidos separados por coma) ────────────
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Puerto del servidor ──────────────────────────────────────
SERVER_PORT=8080

# ── Almacenamiento de reportes ───────────────────────────────
REPORTS_STORAGE_PATH=./reports-storage
